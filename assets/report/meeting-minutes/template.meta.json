{
  "name": "회의록",
  "description": "학교·공공기관의 표준 회의록 양식. 제목·정보표(일시/장소/참석자/작성자)·안건·논의 내용·결정 사항·다음 회의 구조. 학년부 회의, 부서 회의, 위원회 회의 등 모든 종류의 공식 회의 기록에 사용.",
  "fields": [
    {
      "key": "회의_제목",
      "placeholder": "◆회의 제목 (예: 2026학년도 1학기 학년부 회의록)◆",
      "type": "single",
      "required": true,
      "description": "회의록 제목. 보통 '○○○○ 회의록' 또는 '○○○○ 결과'."
    },
    {
      "key": "일시",
      "placeholder": "◆회의 일시 (예: 2026. 5. 30.(토) 14:00~16:00)◆",
      "type": "single",
      "required": true,
      "description": "회의 일시. 날짜는 'YYYY. M. D.(요일)' 형식, 시간은 24시각제 'HH:MM~HH:MM'."
    },
    {
      "key": "장소",
      "placeholder": "◆회의 장소 (예: 본관 3층 회의실)◆",
      "type": "single",
      "required": true,
      "description": "회의 장소."
    },
    {
      "key": "참석자",
      "placeholder": "◆참석자 명단 (예: 교장, 교감, 1·2·3학년부장 등 7명)◆",
      "type": "single",
      "required": true,
      "description": "참석자 명단. 직함 또는 이름. 총 인원 명시 권장."
    },
    {
      "key": "작성자",
      "placeholder": "◆작성자 (예: 김○○ 교사)◆",
      "type": "single",
      "required": true,
      "description": "회의록 작성자."
    },
    {
      "key": "안건",
      "placeholder": "◆회의 안건◆",
      "type": "sequential",
      "max_count": 5,
      "required": true,
      "description": "회의 안건 목록 (1./2./3./4./5.). 양식에 5자리. 미사용 자리는 한글에서 삭제."
    },
    {
      "key": "논의_내용",
      "placeholder": "◆논의 내용◆",
      "type": "sequential",
      "max_count": 5,
      "required": true,
      "description": "안건별 논의 내용. 양식에 5자리. 안건과 1:1 대응 권장."
    },
    {
      "key": "결정_사항",
      "placeholder": "◆결정 사항◆",
      "type": "sequential",
      "max_count": 5,
      "required": false,
      "description": "회의 결정 사항/실행 사항. 양식에 5자리. '담당자', '기한'을 함께 명시하면 좋음."
    },
    {
      "key": "다음_회의",
      "placeholder": "◆다음 회의 안내 (일시·장소·안건). 미정이면 '추후 공지' 입력◆",
      "type": "single",
      "required": false,
      "description": "다음 회의 일정. 미정이면 '추후 공지'."
    }
  ],
  "notes": [
    "회의록은 표가 포함된 양식이라 정보표 영역은 4행 2열 구조로 만들어져 있다.",
    "안건/논의 내용/결정 사항은 1:1 대응이 권장된다 (안건 1번에 대한 논의 1번, 결정 1번).",
    "이 양식은 python-hwpx로 생성된 단순한 구조라 한컴오피스에서 표 디자인(테두리, 셀 너비)을 보완하는 것을 권장."
  ]
}
